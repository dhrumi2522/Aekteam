<%- include('./partials/hrsidebar') %>
  <!-- Add this in your EJS layout or main template head -->
  <script src="https://cdn.tailwindcss.com"></script>

  <div class="min-h-screen bg-gray-50 flex flex-col items-center py-10 px-4">
    <!-- Header -->
    <div class="w-full max-w-4xl flex justify-between items-center mb-8">
      <h1 class="text-3xl font-bold text-gray-800">🎉 Festival Leaves</h1>
      <a href="/dashboard/hr" class="text-sm text-blue-600 hover:text-blue-800 underline">
        ← Back to Dashboard
      </a>
    </div>

    <!-- Add Leave Form -->
    <div class="w-full max-w-4xl bg-white shadow-md rounded-2xl p-6 border border-gray-100">
      <h2 class="text-lg font-semibold text-gray-700 mb-4">Add Festival Leave</h2>
      <form id="addFestivalForm" action="/dashboard/hr/festival-leaves/add" method="POST"
        class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-600 mb-1" for="leave_date">
            Leave Date
          </label>
          <input type="date" name="leave_date" id="leave_date" required
            class="w-full border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 px-3 py-2 text-sm" />
        </div>
        <div class="sm:col-span-2">
          <label class="block text-sm font-medium text-gray-600 mb-1" for="name">
            Festival Name
          </label>
          <input type="text" name="name" id="name" placeholder="e.g. Diwali, Holi, Navratri" required
            class="w-full border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 px-3 py-2 text-sm" />
        </div>
        <div class="sm:col-span-3 flex justify-end">
          <button type="submit"
            class="bg-blue-600 hover:bg-blue-700 text-white font-medium px-6 py-2 rounded-lg transition duration-200">
            + Add Leave
          </button>
        </div>
      </form>
    </div>

    <!-- Leave List Table -->
    <div class="w-full max-w-4xl bg-white shadow-md rounded-2xl mt-10 p-6 border border-gray-100">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-lg font-semibold text-gray-700">Upcoming & Past Festival Leaves</h2>
        <% if (leaves.length> 0) { %>
          <span class="text-sm text-gray-500">Total: <%= leaves.length %></span>
          <% } %>
      </div>

      <% if (leaves.length===0) { %>
        <div class="text-center py-8 text-gray-500">
          <p>No festival leaves added yet.</p>
        </div>
        <% } else { %>
          <div class="overflow-x-auto">
            <table class="min-w-full border border-gray-200 rounded-lg overflow-hidden">
              <thead class="bg-blue-50 text-gray-700 text-sm">
                <tr>
                  <th class="px-4 py-3 text-left font-semibold">Date</th>
                  <th class="px-4 py-3 text-left font-semibold">Festival Name</th>
                  <th class="px-4 py-3 text-center font-semibold">Action</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200 text-sm">
                <% leaves.forEach(leave=> { %>
                  <tr class="hover:bg-gray-50 transition">
                    <td class="px-4 py-3 text-gray-700">
                      <%= leave.leave_date.toDateString() %>
                    </td>
                    <td class="px-4 py-3 text-gray-700 font-medium">
                      <%= leave.name %>
                    </td>
                    <td class="px-4 py-3 text-center">
                      <form action="/dashboard/hr/festival-leaves/delete/<%= leave.id %>" method="POST"
                        class="delete-festival-form inline-block">
                        <button type="submit"
                          class="bg-red-500 hover:bg-red-600 text-white text-xs font-medium px-3 py-1.5 rounded-full transition">
                          Delete
                        </button>
                      </form>
                    </td>
                  </tr>
                  <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script>
    async function submitFormWithSwal(form, options) {
      if (options.confirm) {
        const confirmResult = await Swal.fire({
          title: "Are you sure?",
          text: options.confirm,
          icon: "warning",
          showCancelButton: true,
          confirmButtonColor: "#ef4444",
          cancelButtonColor: "#6b7280",
          confirmButtonText: "Yes, submit!",
          cancelButtonText: "Cancel",
          reverseButtons: true
        });
        if (!confirmResult.isConfirmed) return;
      }

      Swal.fire({
        title: options.loadingTitle,
        html: options.loadingText,
        allowOutsideClick: false,
        didOpen: () => Swal.showLoading()
      });

      try {
        const formData = new FormData(form);
        const payload = Object.fromEntries(formData.entries());
        const hasBody = Object.keys(payload).length > 0;

        const response = await fetch(form.action, {
          method: form.method || "POST",
          headers: hasBody ? { "Content-Type": "application/json" } : undefined,
          body: hasBody ? JSON.stringify(payload) : undefined,
          credentials: "include"
        });

        const result = await response.json();

        if (response.ok && result.success) {
          await Swal.fire({
            title: options.successTitle,
            text: result.message,
            icon: "success",
            confirmButtonColor: "#3b82f6"
          });
          location.reload();
        } else {
          throw new Error(result.message || "Failed to submit request");
        }
      } catch (error) {
        Swal.fire({
          title: "Error!",
          text: error.message,
          icon: "error",
          confirmButtonColor: "#ef4444"
        });
      }
    }

    document.getElementById('addFestivalForm').addEventListener('submit', function (e) {
      e.preventDefault();
      submitFormWithSwal(e.target, {
        loadingTitle: "Adding Festival...",
        loadingText: "Please wait while we add the festival leave.",
        successTitle: "Success!"
      });
    });

    document.querySelectorAll('.delete-festival-form').forEach(form => {
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        submitFormWithSwal(e.target, {
          confirm: "You want to delete this festival leave?",
          loadingTitle: "Deleting...",
          loadingText: "Please wait while we delete the festival leave.",
          successTitle: "Deleted!"
        });
      });
    });
  </script>
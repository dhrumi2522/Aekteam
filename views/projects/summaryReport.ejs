<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Employee Work Summary</title>
    
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        /* General Page Styles */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f4f6f9;
            margin: 0;
            padding: 0;
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar Styles */
        .sidebar {
            width: 250px;
            background: #2c3e50;
            color: white;
            height: 100vh;
            position: fixed;
            overflow-y: auto;
            transition: all 0.3s;
            z-index: 1000;
        }

        /* Main Content Area */
        .main-content {
            flex: 1;
            margin-left: 250px;
            padding: 20px;
            transition: all 0.3s;
        }

        /* Main Container */
        .container {
            max-width: 1200px;
            width: 100%;
            margin: 0 auto;
            background: #ffffff;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.15);
        }

        /* Page Title */
        h1 {
            text-align: center;
            font-size: 28px;
            font-weight: 600;
            color: #333;
            margin-bottom: 25px;
        }

        /* Filters Section */
        .filters {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            gap: 20px;
            background: #f8f9fa;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
        }

        .filter-group {
            flex: 1;
            min-width: 200px;
        }

        .filter-group label {
            font-weight: 600;
            color: #555;
            display: block;
            margin-bottom: 5px;
        }

        .filter-group select,
        .filter-group input {
            width: 100%;
            padding: 10px;
            font-size: 14px;
            border: 1px solid #ccc;
            border-radius: 6px;
            background: #fff;
        }

        /* Charts Container */
        .charts {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            gap: 20px;
            margin-bottom: 30px;
        }

        .chart-container {
            flex: 1;
            min-width: 300px;
            background: #fff;
            border-radius: 8px;
            padding: 15px;
            box-shadow: 0px 3px 6px rgba(0, 0, 0, 0.1);
        }

        .chart-container canvas {
            width: 100% !important;
            height: 300px !important;
        }

        /* Section Title */
        h2 {
            font-size: 24px;
            font-weight: 600;
            margin-top: 30px;
            color: #444;
        }

        /* Table Container */
        .table-container {
            overflow-x: auto;
            border-radius: 8px;
            background: #fff;
            padding: 15px;
            box-shadow: 0px 3px 6px rgba(0, 0, 0, 0.1);
            margin-top: 15px;
        }

        /* Table Styles */
        table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        thead {
            background: #007bff;
            color: #fff;
        }

        thead tr th {
            padding: 14px;
            font-size: 16px;
            font-weight: 500;
        }

        tbody tr {
            border-bottom: 1px solid #ddd;
        }

        tbody tr td {
            padding: 12px;
            font-size: 15px;
            color: #333;
        }

        tbody tr:nth-child(even) {
            background: #f8f9fa;
        }

        tbody tr:hover {
            background: #e9ecef;
        }

        .employee-name {
            font-weight: 600;
            color: #2c3e50;
        }

        .date-header {
            background-color: #e9ecef !important;
            font-weight: 700 !important;
            color: #495057 !important;
            font-size: 16px !important;
        }

        /* Mobile Menu Button */
        .mobile-menu-btn {
            display: none;
            position: fixed;
            top: 15px;
            left: 15px;
            background: #2c3e50;
            color: white;
            border: none;
            border-radius: 4px;
            padding: 10px;
            z-index: 1100;
            cursor: pointer;
        }

        /* Responsive Adjustments */
        @media (max-width: 1200px) {
            .container {
                padding: 20px;
            }
        }

        @media (max-width: 992px) {
            .charts {
                flex-direction: column;
            }
            
            .chart-container {
                width: 100%;
            }
        }

        @media (max-width: 768px) {
            .sidebar {
                width: 0;
                transform: translateX(-100%);
            }
            
            .sidebar.active {
                width: 250px;
                transform: translateX(0);
            }
            
            .main-content {
                margin-left: 0;
            }
            
            .mobile-menu-btn {
                display: block;
            }
            
            .filters {
                flex-direction: column;
            }
            
            .filter-group {
                width: 100%;
            }
        }

        @media (max-width: 576px) {
            .container {
                padding: 15px;
            }
            
            h1 {
                font-size: 24px;
            }
            
            h2 {
                font-size: 20px;
            }
            
            thead tr th,
            tbody tr td {
                padding: 10px;
                font-size: 14px;
            }
        }
    </style>
</head>
<body>
    <!-- Mobile Menu Button -->
    <button class="mobile-menu-btn" id="mobileMenuBtn">☰</button>
    
    <!-- Sidebar -->
    <div class="sidebar" id="sidebar">
        <% if (role === 'hr') { %>
            <%- include('../partials/hrsidebar') %>
        <% } else { %>
            <%- include('../partials/sidebar') %>
        <% } %>
    </div>

    <!-- Main Content -->
    <div class="main-content" id="mainContent">
        <div class="container">
            <h1 class="page-title">📊 Work Hours Summary</h1>
        
            <div class="filters">
                <div class="filter-group">
                    <label for="employee">👨‍💼 Employee:</label>
                    <select id="employee">
                        <option value="">All Employees</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label for="project">📁 Project:</label>
                    <select id="project">
                        <option value="">All Projects</option>
                        <% if (projects && projects.length > 0) { %>
                            <% projects.forEach(proj => { %>
                                <option value="<%= proj.project_name %>"><%= proj.project_name %></option>
                            <% }); %>
                        <% } else { %>
                            <option value="" disabled>No projects available</option>
                        <% } %>
                    </select>
                </div>
                <div class="filter-group">
                    <label for="month">📅 Month:</label>
                    <input type="month" id="month" value="<%= new Date().toISOString().slice(0,7) %>">
                </div>
                <div class="filter-group">
                    <label for="pastMonth">
                        <input type="checkbox" id="pastMonth">
                        Include Previous Month
                    </label>
                </div>
            </div>
        
            <div class="charts">
                <div class="chart-container">
                    <canvas id="workSummaryChart"></canvas>
                </div>
                <div class="chart-container">
                    <canvas id="projectChart"></canvas>
                </div>
            </div>
        
            <h2 class="section-title">📅 Date-wise Work Summary</h2>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Employee</th>
                            <th>Project</th>
                            <th>Work Description</th>
                            <th>Work Hours</th>
                        </tr>
                    </thead>
                    <tbody id="reportTableBody">
                        <tr><td colspan="5">Loading data...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Mobile menu toggle
            const mobileMenuBtn = document.getElementById('mobileMenuBtn');
            const sidebar = document.getElementById('sidebar');
            const mainContent = document.getElementById('mainContent');
            
            mobileMenuBtn.addEventListener('click', function() {
                sidebar.classList.toggle('active');
            });
            
            // Close sidebar when clicking outside on mobile
            document.addEventListener('click', function(event) {
                if (window.innerWidth <= 768 && 
                    !sidebar.contains(event.target) && 
                    !mobileMenuBtn.contains(event.target) && 
                    sidebar.classList.contains('active')) {
                    sidebar.classList.remove('active');
                }
            });
            
            // Filter elements
            const empSelect = document.getElementById("employee");
            const projSelect = document.getElementById("project");
            const monthSelect = document.getElementById("month");
            const pastMonthCheckbox = document.getElementById("pastMonth");
            const reportTableBody = document.getElementById("reportTableBody");
            let workChart = null;
            let projectChart = null;

            // Store employee names mapping
            let employeeNames = {};

            // Function to fetch employee list
            function fetchEmployees() {
                fetch("/dashboard/employee/projects/get-employees")
                    .then(res => {
                        if (!res.ok) throw new Error('Failed to fetch employees');
                        return res.json();
                    })
                    .then(data => {
                        empSelect.innerHTML = '<option value="">All Employees</option>';
                        
                        // Store employee names in mapping
                        data.forEach(emp => {
                            employeeNames[emp.emp_id] = emp.name;
                            let option = document.createElement("option");
                            option.value = emp.emp_id;
                            option.textContent = emp.name;
                            empSelect.appendChild(option);
                        });
                    })
                    .catch(error => {
                        console.error("Error fetching employees:", error);
                    });
            }

            // Function to fetch summary data
            function fetchSummary() {
                const empId = empSelect.value;
                const projectId = projSelect.value;
                const selectedMonth = monthSelect.value;
                const includePastMonth = pastMonthCheckbox.checked;

                let start_date = "", end_date = "";

                if (selectedMonth) {
                    let [year, month] = selectedMonth.split("-");
                    start_date = `${year}-${month}-01`;
                    end_date = new Date(year, month, 0).toISOString().slice(0, 10);
                }

                // Show loading state
                reportTableBody.innerHTML = `<tr><td colspan="5">Loading data...</td></tr>`;

                let url = `/dashboard/employee/projects/get-summary?emp_id=${empId}&project_id=${projectId}&start_date=${start_date}&end_date=${end_date}`;
                
                if (includePastMonth) {
                    url += '&prev_month=true';
                }

                fetch(url)
                    .then(res => {
                        if (!res.ok) throw new Error('Failed to fetch summary data');
                        return res.json();
                    })
                    .then(data => {
                        // Process data for charts and table
                        processAndRenderData(data);
                    })
                    .catch(error => {
                        console.error("Error fetching data:", error);
                        reportTableBody.innerHTML = `<tr><td colspan="5">Error loading data. Please try again.</td></tr>`;
                    });
            }

            // Process data and render everything
            function processAndRenderData(data) {
                // Prepare data for daily chart
                const dailyData = processDailyData(data.daily);
                
                // Render charts
                renderChart(dailyData.labels, dailyData.values, data.daily);
                renderProjectChart(data.projectWise || {});
                
                // Render table with employee-wise data grouped by date
                renderTable(data.daily);
            }

            // Process daily data for chart
            function processDailyData(dailyEntries) {
                const selectedMonth = monthSelect.value;
                let year, month;
                
                if (selectedMonth) {
                    [year, month] = selectedMonth.split("-");
                } else {
                    const now = new Date();
                    year = now.getFullYear();
                    month = (now.getMonth() + 1).toString().padStart(2, '0');
                }
                
                const daysInMonth = new Date(year, month, 0).getDate();
                const labels = Array.from({ length: daysInMonth }, (_, i) => (i + 1).toString());
                const values = new Array(daysInMonth).fill(0);
                
                // Sum hours for each day across all employees
                dailyEntries.forEach(entry => {
                    if (entry.date) {
                        const day = new Date(entry.date).getDate();
                        if (day >= 1 && day <= daysInMonth) {
                            values[day - 1] += parseFloat(entry.hours) || 0;
                        }
                    }
                });
                
                return { labels, values };
            }

            // Function to render bar chart for work summary
            function renderChart(dates, hours, rawData) {
                const canvas = document.getElementById("workSummaryChart");
                if (!canvas) {
                    console.error("Canvas element not found: workSummaryChart");
                    return;
                }

                const ctx = canvas.getContext("2d");
                if (workChart) workChart.destroy();

                workChart = new Chart(ctx, {
                    type: "bar",
                    data: {
                        labels: dates,
                        datasets: [{
                            label: "Total Work Hours (All Employees)",
                            data: hours,
                            backgroundColor: "rgba(54, 162, 235, 0.5)",
                            borderColor: "rgba(54, 162, 235, 1)",
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            tooltip: {
                                callbacks: {
                                    label: function (tooltipItem) {
                                        return `Total Hours: ${tooltipItem.raw.toFixed(2)} hrs`;
                                    }
                                }
                            }
                        },
                        scales: {
                            x: { 
                                title: { 
                                    display: true, 
                                    text: "Day of the Month" 
                                } 
                            },
                            y: { 
                                beginAtZero: true, 
                                title: { 
                                    display: true, 
                                    text: "Total Hours Worked" 
                                } 
                            }
                        }
                    }
                });
            }

            // Function to render project-wise pie chart
            function renderProjectChart(projectHours) {
                const canvas = document.getElementById("projectChart");
                if (!canvas) {
                    console.error("Canvas element not found: projectChart");
                    return;
                }

                const ctx = canvas.getContext("2d");
                if (projectChart) projectChart.destroy();

                // If no project data
                if (Object.keys(projectHours).length === 0) {
                    projectHours = { "No Data": 1 };
                }

                // Generate colors for projects
                const colors = [
                    "#FF6384", "#36A2EB", "#FFCE56", "#4CAF50", "#FF9800",
                    "#9C27B0", "#00BCD4", "#8BC34A", "#FF5722", "#607D8B"
                ];

                projectChart = new Chart(ctx, {
                    type: "pie",
                    data: {
                        labels: Object.keys(projectHours),
                        datasets: [{
                            data: Object.values(projectHours),
                            backgroundColor: colors.slice(0, Object.keys(projectHours).length)
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'top'
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        const label = context.label || '';
                                        const value = context.raw || 0;
                                        const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                        const percentage = Math.round((value / total) * 100);
                                        return `${label}: ${value.toFixed(2)} hours (${percentage}%)`;
                                    }
                                }
                            }
                        }
                    }
                });
            }

            // Function to render data table with date grouping and employee-wise data
            function renderTable(data) {
                reportTableBody.innerHTML = "";

                if (!Array.isArray(data) || data.length === 0) {
                    reportTableBody.innerHTML = `<tr><td colspan="5">No records found for the selected filters.</td></tr>`;
                    return;
                }

                // Sort data by date (descending) and then by employee name
                const sortedData = [...data].sort((a, b) => {
                    const dateCompare = new Date(b.date) - new Date(a.date);
                    if (dateCompare !== 0) return dateCompare;
                    
                    const nameA = a.emp_name || employeeNames[a.emp_id] || '';
                    const nameB = b.emp_name || employeeNames[b.emp_id] || '';
                    return nameA.localeCompare(nameB);
                });

                let currentDate = '';
                let dailyTotal = 0;
                let dailyEntries = [];

                // First pass: calculate daily totals
                const dateTotals = {};
                sortedData.forEach(entry => {
                    if (entry.date) {
                        const dateStr = formatDate(entry.date);
                        if (!dateTotals[dateStr]) {
                            dateTotals[dateStr] = 0;
                        }
                        dateTotals[dateStr] += parseFloat(entry.hours) || 0;
                    }
                });

                // Second pass: render table with date headers and employee rows
                sortedData.forEach((entry, index) => {
                    const entryDate = formatDate(entry.date);
                    const entryDateFull = entry.date;
                    
                    // Add date header if new date
                    if (entryDate !== currentDate) {
                        // Add daily total row for previous date if needed
                        if (currentDate !== '') {
                            addDailyTotalRow(currentDate, dateTotals[currentDate]);
                        }
                        
                        // Add date header
                        const dateHeader = document.createElement("tr");
                        dateHeader.innerHTML = `
                            <td colspan="5" class="date-header">
                                📅 ${entryDate}
                            </td>
                        `;
                        reportTableBody.appendChild(dateHeader);
                        currentDate = entryDate;
                    }

                    // Add employee work entry row
                    const row = document.createElement("tr");
                    
                    // Get employee name (from entry or mapping)
                    const empName = entry.emp_name || employeeNames[entry.emp_id] || entry.emp_id || "Unknown Employee";
                    
                    row.innerHTML = `
                        <td></td>
                        <td><span class="employee-name">${empName}</span></td>
                        <td>${entry.project || "Unknown Project"}</td>
                        <td>${entry.work_description || "N/A"}</td>
                        <td>${entry.hours ? `${parseFloat(entry.hours).toFixed(2)} hrs` : "0.00 hrs"}</td>
                    `;
                    reportTableBody.appendChild(row);
                });

                // Add daily total row for the last date
                if (currentDate !== '') {
                    addDailyTotalRow(currentDate, dateTotals[currentDate]);
                }
            }

            // Helper function to add daily total row
            function addDailyTotalRow(date, total) {
                const totalRow = document.createElement("tr");
                totalRow.style.backgroundColor = "#f8f9fa";
                totalRow.innerHTML = `
                    <td colspan="4" style="text-align: right; font-weight: 600; color: #007bff;">
                        Daily Total Hours:
                    </td>
                    <td style="font-weight: 700; color: #28a745;">
                        ${total.toFixed(2)} hrs
                    </td>
                `;
                reportTableBody.appendChild(totalRow);
                
                // Add empty row for spacing
                const spacerRow = document.createElement("tr");
                spacerRow.innerHTML = `<td colspan="5" style="padding: 5px;"></td>`;
                reportTableBody.appendChild(spacerRow);
            }

            function formatDate(dateStr) {
                if (!dateStr) return "Unknown Date";
                let date = new Date(dateStr);
                return date.toLocaleDateString('en-US', { 
                    weekday: 'short', 
                    year: 'numeric', 
                    month: 'short', 
                    day: 'numeric' 
                });
            }

            // Event listeners for filters
            empSelect.addEventListener("change", fetchSummary);
            projSelect.addEventListener("change", fetchSummary);
            monthSelect.addEventListener("change", fetchSummary);
            pastMonthCheckbox.addEventListener("change", fetchSummary);

            // Initialize the dashboard
            fetchEmployees();
            fetchSummary();
        });
    </script>
</body>
</html>

<%- include('../partials/sidebar') %>
  <!-- Add this in your EJS layout or main template head -->
  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    .main-content {
      margin-left: 270px;
      min-height: 100vh;
      background-color: #f1f4f8;
      padding: 40px;
      transition: all 0.3s;
    }
    @media (max-width: 1024px) {
      .main-content {
        margin-left: 0;
        padding: 20px;
      }
    }
  </style>

  <div class="main-content">
    <div class="max-w-4xl mx-auto py-6">
      <!-- Header -->
      <div class="flex justify-between items-center mb-8">
        <h1 class="text-3xl font-bold text-gray-800 flex items-center gap-2">
          🎉 Festival Leaves
        </h1>
        <a href="/dashboard/employee/home" class="text-sm font-semibold text-blue-600 hover:text-blue-800 flex items-center gap-1 transition">
          — Back to Home
        </a>
      </div>

      <!-- Leave List Table -->
      <div class="bg-white shadow-md rounded-2xl p-6 border border-gray-100">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-lg font-semibold text-gray-700">Upcoming Festival Leaves</h2>
          <% if (leaves.length > 0) { %>
            <span class="bg-blue-100 text-blue-800 text-xs font-semibold px-3 py-1 rounded-full">
              Total: <%= leaves.length %>
            </span>
          <% } %>
        </div>

        <% if (leaves.length === 0) { %>
          <div class="text-center py-10 text-gray-500">
            <p class="text-base">No upcoming festival leaves found.</p>
          </div>
        <% } else { %>
          <div class="overflow-x-auto rounded-xl border border-gray-100">
            <table class="min-w-full divide-y divide-gray-150">
              <thead class="bg-slate-50 text-gray-500 text-xs uppercase tracking-wider">
                <tr>
                  <th class="px-6 py-3.5 text-left font-semibold">Date</th>
                  <th class="px-6 py-3.5 text-left font-semibold">Festival Name</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-150 bg-white text-sm text-gray-700">
                <% leaves.forEach(leave => { %>
                  <tr class="hover:bg-slate-50/80 transition-colors">
                    <td class="px-6 py-4 whitespace-nowrap">
                      <%= leave.leave_date.toDateString() %>
                    </td>
                    <td class="px-6 py-4 font-medium text-gray-900">
                      <%= leave.name %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
